{
  "name": "slot-game-kit",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "vite --host 127.0.0.1 --port 8081",
    "dev": "vite --host 127.0.0.1 --port 8081",
    "build": "tsc --noEmit && vite build --outDir dist --emptyOutDir",
    "format": "biome format --write src scripts",
    "lint": "biome lint src scripts",
    "check": "biome check src scripts",
    "assets:delivery": "tsx scripts/generate-delivery-atlases.ts",
    "test:smoke": "tsx scripts/smoke-test.ts",
    "test": "vitest run && npm run test:smoke"
  },
  "dependencies": {
    "pixi.js": "^8.2.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.60.0",
    "sharp": "^0.34.5",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^6.0.0",
    "vitest": "^4.1.7"
  }
}
